{
  "family": "mopl-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::542508027261:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::542508027261:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "mopl-container",
      "image": "542508027261.dkr.ecr.ap-northeast-2.amazonaws.com/sb08/mopl:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "prod"
        },
        {
          "name": "SPRING_DATASOURCE_URL",
          "value": "jdbc:postgresql://mopl-db.cf0qwgqwodaf.ap-northeast-2.rds.amazonaws.com:5432/mopl"
        },
        {
          "name": "POSTGRES_DB",
          "value": "mopl"
        },
        {
          "name": "POSTGRES_USERNAME",
          "value": "mopl_user"
        }
      ],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "arn:aws:ssm:ap-northeast-2:542508027261:parameter/mopl/db/password"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/mopl-task",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}